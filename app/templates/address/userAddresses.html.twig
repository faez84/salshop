{% extends 'base.html.twig' %}
{% block body %}
	{% set hasAddresses = addresses|length > 0 %}
	<div class="bg-slate-50">
		<div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
			<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
				<div class="mb-6 border-b border-slate-200 pb-5">
					<p class="text-xs font-semibold uppercase tracking-[0.22em] text-cyan-700">Checkout</p>
					<h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Select delivery address</h1>
					<p class="mt-2 text-sm text-slate-600">Choose one saved address to continue to payment.</p>
				</div>

				<form action="{{ path('basket_payment') }}" method="post" class="space-y-6">
					<div class="space-y-3">
						{% for id, address in addresses %}
							<label class="flex cursor-pointer items-start gap-3 rounded-lg border border-slate-200 bg-white p-4 transition hover:border-cyan-300 hover:bg-cyan-50/30">
								<input
									name="addressId"
									type="radio"
									value="{{ id }}"
									class="mt-1 h-4 w-4 border-slate-300 text-cyan-700 focus:ring-cyan-400"
									{% if loop.first %}checked{% endif %}
								/>
								<span class="text-sm leading-relaxed text-slate-700">{{ address }}</span>
							</label>
						{% else %}
							<div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
								You do not have any saved addresses yet.
							</div>
						{% endfor %}
					</div>

					<div class="flex flex-wrap items-center gap-3">
						<button
							type="submit"
							{% if not hasAddresses %}disabled{% endif %}
							class="flex items-center gap-2 rounded-md px-6 py-2 mr-2 text-white focus:outline-none focus:ring-2 focus:ring-offset-2 {% if hasAddresses %}bg-indigo-600 hover:bg-indigo-700 focus:ring-indigo-500{% else %}cursor-not-allowed bg-gray-200 focus:ring-gray-200{% endif %}"
						>
							Continue to payment
						</button>
						<a href="{{ path('add_user_address') }}" class="inline-flex items-center rounded-md border border-slate-300 bg-white px-6 py-2.5 font-semibold text-slate-700 transition-colors hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2">
							Add address
						</a>
					</div>
				</form>
			</div>
		</div>
	</div>
{% endblock %}
