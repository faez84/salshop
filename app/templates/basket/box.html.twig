<article class="p-3 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
	<a href="{{ path('product_details', {id: product.id}) }}" class="group block">
		<div>
			<a href="{{ path('product_details', {id: product.id}) }}" class="group">
				<div class="aspect-h-1 aspect-w-1 w-full h-72 overflow-hidden rounded-lg  xl:aspect-h-8 xl:aspect-w-7">
					<img class="w-42 h-42" src="/images/products/{{ product.image }}" alt="Tall slender porcelain bottle with natural clay textured body and cork stopper." class="h-full w-full object-cover object-center group-hover:opacity-75">
				</div>
				<h3 class="mt-4 text-sm text-gray-700">{{ product.title }}</h3>
				<p class="mt-1 text-lg font-medium text-gray-900">$
					{{ product.price }}</p>
			</a>
			Count:
			{{ basketProducts[product.id] ?? 0 }}<a href="{{ path('add_basket_product_count', {productId: product.id}) }}" class="group">+</a>
			<div>
			Delete <a href="{{path('delete_basket_product', {productId: product.id})}}" class="group">x</a>
			</div>
		</div>
	</a>
</article>

