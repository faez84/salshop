{% extends 'base.html.twig' %}
{% block body %}

	<div class="">
		<div class="bg-white">

			<div class="mx-auto max-w-2xl px-4 py-16 sm:px-6 sm:py-24 lg:max-w-7xl lg:px-8">
				<p class="text-3xl font-semibold uppercase tracking-[0.22em] text-cyan-700">Products</p>
							

				<div class="grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 xl:gap-x-8">
					{% for product in products %}
{% include 'basket/box.html.twig' with {'product': product, 'basketProducts': basketProducts} only %}
						 
					{% endfor %}
				</div>
			</div>
		</div>

		<div>
			<a href="{{ path('show_user_address') }} ">
				<button class="bg-indigo-600 flex gap-2 items-center text-white px-6 py-2 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">

					Continue
				</button>
			</a>
		</div>
	</div>
{% endblock %}

